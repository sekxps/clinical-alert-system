# ==================================================================
# Clinical Alert System (CAS) — WebSocket Dispatcher Configuration
# ==================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file to version control.

# -------------------------------------------------------------
# HIS (Hospital Information System) Database
# Used to enrich alert payloads with patient metadata.
# This account should have READ-ONLY (SELECT) privileges only.
# -------------------------------------------------------------
HIS_HOST=<your_his_db_host>
HIS_PORT=3306
HIS_USER=cas_readonly
HIS_PASSWORD=<your_his_db_password>
HIS_DATABASE=<your_his_database_name>

# -------------------------------------------------------------
# CAS (Clinical Alert System) Database
# Used to read and acknowledge alerts.
# -------------------------------------------------------------
CAS_HOST=<your_cas_db_host>
CAS_PORT=3306
CAS_USER=cas_user
CAS_PASSWORD=<your_cas_db_password>
CAS_DATABASE=cas_db

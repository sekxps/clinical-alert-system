# =============================================================
# Clinical Alert System (CAS) — Desktop Client Configuration
# =============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file to version control.

# -------------------------------------------------------------
# WebSocket Dispatcher URL
# Point this to the running cas-ws-dispatcher service.
# Use ws:// for plain or wss:// for TLS-secured connections.
# -------------------------------------------------------------
CAS_WS_URL=ws://<dispatcher_host>:8000/ws/alerts

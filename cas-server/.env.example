# =============================================================
# Clinical Alert System (CAS) — Server Configuration Template
# =============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file to version control.

# -------------------------------------------------------------
# HIS (Hospital Information System) Database
# The HIS DB account MUST have READ-ONLY (SELECT) privileges only.
# -------------------------------------------------------------
HIS_HOST=<your_his_db_host>
HIS_PORT=3306
HIS_USER=cas_readonly
HIS_PASSWORD=<your_his_db_password>
HIS_DATABASE=<your_his_database_name>

# -------------------------------------------------------------
# CAS (Clinical Alert System) Database
# This account needs full CRUD privileges on the cas_db schema.
# -------------------------------------------------------------
CAS_HOST=<your_cas_db_host>
CAS_PORT=3306
CAS_USER=cas_user
CAS_PASSWORD=<your_cas_db_password>
CAS_DATABASE=cas_db

# -------------------------------------------------------------
# Polling Settings
# -------------------------------------------------------------
POLL_INTERVAL_SEC=10

# -------------------------------------------------------------
# WebSocket Dispatcher URL
# URL to the cas-ws-dispatcher service.
# -------------------------------------------------------------
WS_DISPATCH_URL=ws://localhost:8000/ws/dispatch

# -------------------------------------------------------------
# Morpromt LINE API (Optional — leave blank to disable LINE alerts)
# -------------------------------------------------------------
MORPROMT_CLIENT_KEY=<your_morpromt_client_key>
MORPROMT_SECRET_KEY=<your_morpromt_secret_key>
